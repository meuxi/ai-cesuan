# ==========================================
# AI 占卜系统 - 环境变量配置模板
# ==========================================

# ============ 必填配置 ============

# OpenAI API 密钥（必填）
# 获取地址：https://platform.openai.com/api-keys
api_key=sk-your-openai-api-key-here

# ============ 可选配置 ============

# OpenAI API 地址（可选，默认为官方地址）
# 如果使用代理或第三方服务，请修改此项
api_base=https://api.openai.com/v1

# OpenAI 模型名称（可选，默认 gpt-3.5-turbo）
# 可选值：gpt-3.5-turbo, gpt-4, gpt-4-turbo-preview 等
model=gpt-3.5-turbo

# ============ GitHub OAuth 登录配置（可选）============

# GitHub OAuth Client ID
# 获取地址：https://github.com/settings/developers
github_client_id=your-github-client-id

# GitHub OAuth Client Secret
github_client_secret=your-github-client-secret

# JWT 密钥（用于用户认证，建议使用强密码）
# 生成方法：openssl rand -hex 32
jwt_secret=your-very-strong-secret-key-here

# ============ 速率限制配置（可选）============

# 是否启用速率限制（默认 true）
enable_rate_limit=true

# 未登录用户速率限制：60次/小时
# 格式：最大请求数,时间窗口(秒)
rate_limit=60,3600

# 已登录用户速率限制：600次/小时
user_rate_limit=600,3600

# ============ 缓存配置（可选）============

# 缓存类型：memory（内存）或 redis
cache_client_type=memory

# Redis 连接地址（当 cache_client_type=redis 时需要）
# redis_url=redis://localhost:6379/0

# Upstash Redis API（Vercel 部署推荐）
# KV_REST_API_URL=https://your-upstash-redis-url
# KV_REST_API_TOKEN=your-upstash-token

# ============ Google AdSense 配置（可选）============

# Google AdSense 发布商 ID
ad_client=ca-pub-your-adsense-id

# Google AdSense 广告单元 ID
ad_slot=your-ad-slot-id

# ============ 其他配置（可选）============

# 项目名称（用于日志和缓存键前缀）
project_name=ai-divination

# 购买链接（显示在设置页面）
purchase_url=https://your-purchase-url.com

# ==========================================
# 配置说明：
# 1. 复制此文件为 .env 并填写实际值
# 2. 至少需要配置 api_key 才能正常运行
# 3. 生产环境务必修改 jwt_secret 为强密码
# 4. 不要将 .env 文件提交到 Git 仓库
# ==========================================
