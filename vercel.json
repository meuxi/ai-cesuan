{
    "buildCommand": "pip install -r requirements.txt && cd frontend && pnpm install && pnpm build",
    "outputDirectory": "dist",
    "installCommand": "pip install -r requirements.txt",
    "framework": null,
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "main.py"
        },
        {
            "src": "/docs",
            "dest": "main.py"
        },
        {
            "src": "/openapi.json",
            "dest": "main.py"
        },
        {
            "src": "/static/(.*)",
            "dest": "/dist/static/$1"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/dist/assets/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/dist/favicon.ico"
        },
        {
            "src": "/(.*)",
            "dest": "/dist/$1"
        }
    ],
    "env": {
        "PYTHON_VERSION": "3.11"
    }
}
