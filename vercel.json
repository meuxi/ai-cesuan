{
    "version": 2,
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.11"  // 明确指定与本地一致的 Python 版本
            }
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist",
                "installCommand": "npm install",  // 强制安装依赖
                "buildCommand": "npm run build || echo '前端构建跳过（仅API部署）'"  // 构建失败兜底
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "main.py"
        },
        {
            "src": "/docs",
            "dest": "main.py"
        },
        {
            "src": "/openapi.json",
            "dest": "main.py"
        },
        {
            "src": "/health",
            "dest": "main.py"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/frontend/dist/assets/$1",  // 精准映射前端打包后的资源路径
            "headers": {
                "Cache-Control": "public, max-age=31536000, immutable"  // 静态资源强缓存
            }
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/dist/$1",
            "rewrite": true  // 关键：SPA 路由刷新不 404
        }
    ],
    "env": {
        "VERCEL": "1"
    }
}
